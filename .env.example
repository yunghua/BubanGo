# BubanGo environment variables
# Copy this file to .env.local and fill in your own Supabase project values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / public key (safe to expose to the browser; RLS protects data).
# Do NOT put the service_role key here or anywhere in the repo.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Active data backend:
#   supabase -> use Supabase (default)
#   local    -> use the localStorage MVP repository (dev fallback)
NEXT_PUBLIC_DATA_BACKEND=supabase

# --- LINE Login & notification binding ---------------------------------------
# These need NO app env vars. LINE Login is a Supabase Auth Custom OAuth provider
# (custom:line); the LINE Channel secret lives only in the Supabase Dashboard.
# LINE notification binding derives the LINE identity from the signed-in user's
# Supabase session (routes /api/line/link-from-auth + /api/line/unlink).
# See docs/LINE_LOGIN_SETUP.md and docs/LINE_ACCOUNT_BINDING.md.
#
# The old NEXT_PUBLIC_LIFF_ID / LINE_CHANNEL_ID vars were removed in v0.1.7 (the
# LIFF-token binding flow is gone); no code reads them — you can safely delete
# them from any existing .env.local.

# --- LINE push notifications (Messaging API) ---------------------------------
# Server-only access token for the LINE Messaging API channel. Used to push an
# 「已錄取」 notice to a worker when a shop owner accepts their application
# (POST /api/applications/[applicationId]/accept). Read ONLY in
# src/lib/line/line-messaging.ts.
#
# If unset, accepting still works and the push is simply skipped
# (status "skipped_unconfigured") — so this is optional for local dev.
#
# SECURITY:
#   * Server-only — do NOT prefix with NEXT_PUBLIC_ (that would ship it to the
#     browser). Never log it; never return it in an API response.
#   * This is the Messaging API channel access token, NOT the LINE Login channel
#     secret. The Messaging API channel must live under the SAME LINE provider as
#     the Login channel so the stored line_user_id is addressable for push.
#   * Set it in Vercel env (Production + Preview, mark Sensitive); add it to
#     .env.local only if you need to test push locally. Never commit a real token.
LINE_CHANNEL_ACCESS_TOKEN=
