# BubanGo environment variables
# Copy this file to .env.local and fill in your own Supabase project values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / public key (safe to expose to the browser; RLS protects data).
# Do NOT put the service_role key here or anywhere in the repo.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Active data backend:
#   supabase -> use Supabase (default)
#   local    -> use the localStorage MVP repository (dev fallback)
NEXT_PUBLIC_DATA_BACKEND=supabase

# --- LINE LIFF / account binding (optional) ---------------------------------
# Leave BOTH blank to run BubanGo as a normal web app (the LINE binding card
# simply shows an "open in LINE" state). See docs/LIFF_SETUP.md.

# LIFF app id from the LINE Developers console (LINE Login channel -> LIFF).
# Public — exposed to the browser to initialize the LIFF SDK.
# Format looks like: 1234567890-abcDEfgh
NEXT_PUBLIC_LIFF_ID=

# Numeric Channel ID of the LINE Login channel the LIFF app belongs to.
# Server-only — used to verify the audience of LINE ID tokens.
# This is the Channel ID, NOT the Channel secret. Never commit the Channel secret.
LINE_CHANNEL_ID=
